# Strategy selection
# - mock: offline, deterministic
# - suno: calls SunoApi.org
GENERATOR_STRATEGY=mock

# Docker/deployment
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,backend
FRONTEND_ORIGIN=http://localhost:3000
LOGIN_REDIRECT_URL=http://localhost:3000/api/auth/google/jwt-redirect/
LOGOUT_REDIRECT_URL=http://localhost:3000/

# Suno API (required only when GENERATOR_STRATEGY=suno)
# DO NOT put real secrets in this file if you plan to commit it.
SUNO_API_KEY=

# Optional Suno settings
SUNO_API_BASE_URL=https://api.sunoapi.org/api/v1
SUNO_MODEL=V4_5ALL
SUNO_CUSTOM_MODE=false
SUNO_INSTRUMENTAL=false
# Webhook callback URL.
# Some SunoApi.org deployments require this (you'll get: "Please enter callBackUrl").
# It must be a publicly reachable HTTPS URL that Suno can POST to.
# For local dev, the easiest option is to use a temporary webhook URL from https://webhook.site
# (copy the full URL it gives you; don't leave placeholders like <your-uuid>).
SUNO_CALLBACK_URL=
SUNO_HTTP_TIMEOUT_SECONDS=30

# Google OAuth (required for OAuth login)
SOCIAL_AUTH_GOOGLE_OAUTH2_KEY=
SOCIAL_AUTH_GOOGLE_OAUTH2_SECRET=
